{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": ["ES2022"],
    "outDir": "skills/ohmyclaw/dist",
    "rootDir": "skills/ohmyclaw/src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": false,
    "sourceMap": false,
    "resolveJsonModule": true
  },
  "include": ["skills/ohmyclaw/src/**/*"],
  "exclude": ["node_modules", "skills/ohmyclaw/dist"]
}
