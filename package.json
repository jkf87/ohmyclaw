{
  "name": "ohmyclaw",
  "version": "1.4.0",
  "description": "OpenClaw용 멀티프로바이더/멀티계정 라우팅 하네스 + 자체 runtime(state/hooks/MCP/lifecycle)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jkf87/ohmyclaw"
  },
  "type": "module",
  "scripts": {
    "build:mcp": "tsc -p tsconfig.json",
    "build:mcp:check": "tsc -p tsconfig.json --noEmit",
    "mcp": "node skills/ohmyclaw/dist/mcp-server.js"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
